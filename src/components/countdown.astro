---
import { siteConfig } from '~/config/site.config';
---

<div class="countdown-wrapper" data-aos="fade-up">
  <h1 class="countdown-title font-extrabold tracking-tight text-2xl">{siteConfig.dates.title}</h1>
  <div class="time font-bold uppercase">
    <span>
      <div id="d" class="countdown-number">00</div>
      <span class="countdown-label">Días</span>
    </span>
    <span>
      <div id="h" class="countdown-number">00</div>
      <span class="countdown-label">Horas</span>
    </span>
    <span>
      <div id="m" class="countdown-number">00</div>
      <span class="countdown-label">Minutos</span>
    </span>
    <span>
      <div id="s" class="countdown-number">00</div>
      <span class="countdown-label">Segundos</span>
    </span>
  </div>
</div>
<script>
  import AOS from 'aos';
  import 'aos/dist/aos.css';
  import { siteConfig } from '~/config/site.config';
  AOS.init({
    duration: 750
  });
  const d = document.getElementById('d');
  const h = document.getElementById('h');
  const m = document.getElementById('m');
  const s = document.getElementById('s');

  function getTrueNumber(num: any) {
    return num < 10 ? '0' + num : num;
  }

  function calculateRemainingTime() {
    const comingYear = new Date().getFullYear() + 1;
    const comingDate = new Date(siteConfig.dates.masterclass);

    const now = new Date();
    // console.log(now);
    // console.log(comingDate);
    const remainingTime = comingDate.getTime() - now.getTime();
    const days = Math.floor(remainingTime / (1000 * 60 * 60 * 24));
    const hours = Math.floor((remainingTime % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins = Math.floor((remainingTime % (1000 * 60 * 60)) / (1000 * 60));
    const secs = Math.floor((remainingTime % (1000 * 60)) / 1000);

    if (d) {
      d.innerHTML = getTrueNumber(days);
    }
    if (h) {
      h.innerHTML = getTrueNumber(hours);
    }
    if (m) {
      m.innerHTML = getTrueNumber(mins);
    }
    if (s) {
      s.innerHTML = getTrueNumber(secs);
    }

    return remainingTime;
  }

  function initCountdown() {
    const interval = setInterval(() => {
      const remainingTimeInMs = calculateRemainingTime();

      if (remainingTimeInMs <= 1000) {
        clearInterval(interval);
        initCountdown();
      }
    }, 1000);
  }

  initCountdown();
</script>
<style>
  .countdown-wrapper {
    text-align: center;
    user-select: none;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(236, 72, 153, 0.18);
    border-radius: 1rem;
    padding: 1rem 1.5rem;
    box-shadow: 0 10px 30px rgba(168, 85, 247, 0.18);
  }

  .countdown-title {
    color: #1f1f1f;
    margin: 0 0 0.6rem;
    background: linear-gradient(135deg, #ec4899, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .time {
    color: #1f1f1f;
    text-transform: uppercase;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }

  .time > span {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 10px;
  }

  .countdown-number {
    font-size: 1.85rem;
    font-weight: 800;
    color: #ec4899;
    line-height: 1;
  }

  .countdown-label {
    font-size: 0.7rem;
    color: #6b7280;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-top: 0.25rem;
  }

  @media (max-width: 740px) {
    .countdown-wrapper {
      padding: 0.85rem 1rem;
    }
    .countdown-title {
      font-size: 1.25rem;
    }
    .countdown-number {
      font-size: 2rem;
    }
    .countdown-label {
      font-size: 0.65rem;
    }
  }
</style>
