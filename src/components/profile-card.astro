---
import { Image } from 'astro:assets';
import foto from '~/assets/foto.webp';
import { siteConfig } from '~/config/site.config';
---

<div
  class="profile-card grid max-h-[400px] w-2/3 max-w-64 rounded-xl bg-white sm:w-10/12"
  data-aos="fade-up"
  style="box-shadow: 0 12px 36px rgba(168, 85, 247, 0.18); border: 1px solid rgba(236, 72, 153, 0.18);"
>
  <Image class="profile-image ml-[-6%] rounded-full" src={foto} alt="Profile picture" />
  <div class="profile-info flex flex-col items-center p-4">
    <h1 class="mb-2 font-bold text-xl" style="color: #1f1f1f;">
      {siteConfig.author}
    </h1>
    <p class="text-sm" style="color: #ec4899; font-weight: 600;">{siteConfig.authorSubtitle}</p>
  </div>
</div>

<script>
  import AOS from 'aos';
  import 'aos/dist/aos.css';
  AOS.init({
    duration: 750
  });
</script>
