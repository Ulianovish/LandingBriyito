---
import { Image } from 'astro:assets';
import rocket from '~/assets/rocket.svg';
import learn from '~/assets/learn.svg';
import trophy from '~/assets/trophy.svg';
import store from '~/assets/store.svg';
import { siteConfig } from '~/config/site.config';
const icons = {
  learn,
  store,
  rocket,
  trophy
};
---

<div class="gradient relative z-10 grid space-y-12 px-8 py-10 min-[449px]:px-4">
  <div
    class="gradient-text text-center font-extrabold tracking-tighter text-3xl"
    data-aos="fade-up"
  >
    4 CLASES CON EL PASO A PASO<span class="hidden min-[480px]:inline min-[900px]:hidden"
      ><br /></span
    > QUE ME PERMITIÓ <span class="max-[900px]:hidden"><br /></span> CREAR UN<span
      class="hidden min-[480px]:inline min-[900px]:hidden"><br /></span
    > NEGOCIO RENTABLE EN LÍNEA
  </div>
  <div
    class="inline-flex max-w-[1100px] flex-wrap justify-center gap-4 justify-self-center min-[900px]:gap-8"
  >
    {
      siteConfig.classes.map((classItem) => (
        <div class="card w-[352px]" data-aos="fade-up">
          <div class="card-header">
            <div class="img-container">
              <Image src={icons[classItem.icon as keyof typeof icons]} alt={classItem.title} />
            </div>
            <div class="card-titles">
              <p class="card-label">{classItem.title}</p>
              <h3 class="card-subtitle">{classItem.subtitle}</h3>
            </div>
          </div>
          <p class="card-description">{classItem.description}</p>
        </div>
      ))
    }
  </div>
</div>

<script>
  import AOS from 'aos';
  import 'aos/dist/aos.css';
  AOS.init({
    duration: 750
  });
</script>

<style>
  .card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border-radius: 1rem;
    background-color: #ffffff;
    border: 1px solid rgba(236, 72, 153, 0.15);
    box-shadow: 0 8px 28px rgba(168, 85, 247, 0.1);
    transition: all 200ms ease;
    gap: 0.75rem;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(236, 72, 153, 0.4);
    box-shadow: 0 16px 40px rgba(236, 72, 153, 0.18);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .img-container {
    height: 3.5rem;
    width: 3.5rem;
    flex-shrink: 0;
  }

  .img-container img {
    width: 100%;
    height: 100%;
  }

  .card-titles {
    display: flex;
    flex-direction: column;
    justify-content: center;
    line-height: 1.15;
  }

  .card-label {
    margin: 0;
    color: #ec4899;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .card-subtitle {
    margin: 0;
    color: #1f1f1f;
    font-weight: 800;
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .card-description {
    margin: 0;
    color: #4b5563;
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.5;
    letter-spacing: 0.1px;
  }

  .gradient {
    background-color: transparent;
  }

  @media (max-width: 900px) {
    .card {
      width: 100%;
    }
  }
</style>
